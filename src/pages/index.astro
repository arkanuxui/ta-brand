          <div class="swatch"><div class="chip" style="background:#ef3340;"></div><div class="meta"><div><div class="name">Red Thread</div><div class="hex">#EF3340</div><div class="val">RGB 239 51 64</div><div class="val">CMYK 0 79 73 6</div></div><CopyButton client:visible value="#EF3340" /></div></div>
