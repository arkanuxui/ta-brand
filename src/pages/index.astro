---
import '../styles/global.css';
import CopyButton from '../components/CopyButton.jsx';

// Normalize the base (Astro's BASE_URL has no trailing slash) so asset
// paths join cleanly regardless of how `base` is configured.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Absolute origin + base, for canonical and social-share (OG/Twitter) URLs.
const siteUrl = (import.meta.env.SITE || 'https://arkanuxui.github.io') + base;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Tailored Applications — Brand Guidelines</title>
  <meta name="description" content="The Tailored Applications brand hub — logo, color, typography, and tone & voice." />
  <meta name="author" content="Tailored Applications" />
  <link rel="canonical" href={`${siteUrl}/`} />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon/Favicon.svg`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon/favicon-32.png`} />
  <link rel="apple-touch-icon" href={`${base}/favicon/apple-touch-icon.png`} />
  <link rel="manifest" href={`${base}/site.webmanifest`} />

  <!-- Open Graph / social share -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Tailored Applications" />
  <meta property="og:title" content="Tailored Applications — Brand Guidelines" />
  <meta property="og:description" content="The Tailored Applications brand hub — logo, color, typography, and tone & voice." />
  <meta property="og:url" content={`${siteUrl}/`} />
  <meta property="og:image" content={`${siteUrl}/social/og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Tailored Applications — Brand Guidelines" />
  <meta name="twitter:description" content="The Tailored Applications brand hub — logo, color, typography, and tone & voice." />
  <meta name="twitter:image" content={`${siteUrl}/social/og-image.jpg`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+Arabic:wght@400;500;700&display=swap" rel="stylesheet" />
  <meta name="theme-color" content="#ffffff" />
  <!-- Set theme before first paint to avoid a flash of the wrong mode -->
  <script is:inline>
    (function () {
      // Always start each page at the top instead of restoring the previous
      // scroll position on reload.
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      // The wordmark/intro nav leaves "#introduction" in the URL; on reload
      // that makes the browser jump past the hero. Drop it (runs before the
      // browser scrolls to the fragment). Real deep links (#logo, #color, …)
      // are still honored.
      if (location.hash === '#introduction') history.replaceState(null, '', location.pathname + location.search);
      try {
        var stored = localStorage.getItem('theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', theme === 'dark' ? '#191919' : '#ffffff');
      } catch (e) {}
      // Skip the intro loader if we've already shown it this session (no flash)
      try { if (sessionStorage.getItem('ta-visited')) document.documentElement.classList.add('loaded'); } catch (e) {}
    })();
  </script>
</head>
<body>
  <!-- Intro loader: drifting brand gradient + counting percentage (once per session) -->
  <div id="loader" role="status" aria-label="Loading"><span class="loader-pct" id="loaderPct">0%</span></div>
  <script is:inline>
    (function () {
      if (document.documentElement.classList.contains('loaded')) return;
      var loader = document.getElementById('loader');
      var pctEl = document.getElementById('loaderPct');
      if (!loader || !pctEl) return;
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var dur = reduce ? 350 : 2000, start = null, last = -1;
      function finish() {
        try { sessionStorage.setItem('ta-visited', '1'); } catch (e) {}
        document.documentElement.classList.add('loaded');
        loader.classList.add('done');
        var done = function () { if (loader && loader.parentNode) loader.parentNode.removeChild(loader); };
        loader.addEventListener('transitionend', done, { once: true });
        setTimeout(done, 900);
      }
      function tick(t) {
        if (start === null) start = t;
        var p = Math.min(1, (t - start) / dur);
        var eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
        var val = Math.round(eased * 100);
        if (val !== last) { last = val; pctEl.textContent = val + '%'; }
        if (p < 1) requestAnimationFrame(tick); else finish();
      }
      requestAnimationFrame(tick);
    })();
  </script>
  <button class="menu-btn" id="menuBtn" aria-label="Open navigation">☰</button>
  <div class="scrim" id="scrim"></div>

  <div class="app">
    <!-- ===== Sidebar ===== -->
    <aside class="sidebar" id="sidebar">
      <button class="nav-close" id="navClose" type="button" aria-label="Close navigation">✕</button>
      <a class="wordmark" href="#introduction" data-spy="introduction" aria-label="Tailored Applications">
        <span class="wordmark-logo" role="img" aria-label="Tailored Applications"></span>
      </a>
      <hr class="divider" />
      <ul class="nav">
        <li><a href="#introduction" data-spy="introduction">Introduction</a></li>
        <li><a href="#logo" data-spy="logo">Logo</a></li>
        <li><a href="#color" data-spy="color">Color</a></li>
        <li><a href="#typography" data-spy="typography">Typography</a></li>
        <li><a href="#tone-voice" data-spy="tone-voice">Tone &amp; Voice</a></li>
        <li><div class="soon">Patterns <span class="badge">Coming soon</span></div></li>
        <li><div class="soon">Illustration <span class="badge">Coming soon</span></div></li>
        <li><div class="soon">Photography <span class="badge">Coming soon</span></div></li>
      </ul>
      <div class="theme-toggle" role="group" aria-label="Color theme">
        <button type="button" class="theme-opt" data-theme-value="light" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          Light
        </button>
        <button type="button" class="theme-opt" data-theme-value="dark" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          Dark
        </button>
      </div>
      <a class="download-all" href={`${base}/TA-Brand-Guideline-by-Design-Dept-2025.zip`} download>
        <span class="dl-icon">↓</span>
        <span>Download Assets<small>ZIP · 104 MB</small></span>
      </a>
    </aside>

    <!-- ===== Main ===== -->
    <main class="main">

      <!-- Introduction -->
      <section class="section" id="introduction">
        <p class="eyebrow">Introduction</p>
        <h1 class="intro-headline">Welcome to the Tailored Applications brand guidelines.</h1>
        <p class="lede">This is the system behind how Tailored Applications looks, sounds, and shows up — from a business card to a product screen. It's the brief we hand anyone designing, building, or writing for the brand, so everything feels like it came from one company.</p>
        <p class="intro-body">Tailored Applications designs and builds custom digital products for enterprise and growing businesses, concept to launch. The brand carries that same idea: precise and technical, but warm and human — bold without shouting. Made-to-measure, like the apps we ship.</p>
        <p class="intro-body"><strong>What's ready:</strong> the foundations are complete — the logo, color, typography, and voice &amp; tone that hold the brand together. <strong>Still in progress:</strong> the pattern, illustration style, and photography direction — we're still working on those.</p>
        <p class="intro-body">Treat the finished foundations as fixed and the rest as a toolkit. When something isn't spelled out here, return to the spirit: clear, confident, and tailored to fit. Get these right and every touchpoint reinforces the same brand — the consistency that turns a mark into something people recognize and trust.</p>
      </section>

      <!-- Logo -->
      <section class="section" id="logo">
        <p class="eyebrow">01 — Identity</p>
        <h2 class="section-title">Logo <a class="anchor" href="#logo" aria-label="Copy link to section">#</a></h2>
        <p class="lede">How to use the Tailored Applications logo, its one-color treatments, and where it must not go.</p>

        <div class="logo-part">
          <span class="logo-part-num">Section 1</span>
          <h3 class="logo-part-title">Combination logo</h3>
        </div>

        <!-- Primary combination logo — full width -->
        <div class="card logo-primary">
          <div class="specimen"><img src={`${base}/logo/section-1/combination-logo.png`} alt="Tailored Applications primary combination logo" /></div>
        </div>

        <hr class="logo-sep" />

        <!-- Clearspace — brief text + image -->
        <div class="logo-row">
          <div class="logo-row-text">
            <p class="subhead" style="margin:0 0 8px;">Clearspace</p>
            <p class="note" style="margin:0;">Always keep clear space around the logo so it stays legible and uncluttered. Maintain a margin equal to the height of the "T" mark on every side, and keep type, imagery, and page edges outside this zone.</p>
          </div>
          <div class="card"><div class="specimen"><img src={`${base}/logo/section-1/clearspace.png`} alt="Logo clearspace guidelines" /></div></div>
        </div>

        <!-- Minimum size — brief text + image -->
        <div class="logo-row">
          <div class="logo-row-text">
            <p class="subhead" style="margin:0 0 8px;">Minimum size</p>
            <p class="note" style="margin:0;">The width of the logo cannot be displayed smaller than 88 pixels (digital) or 2.328 cm (print). The height of the logo cannot be displayed smaller than 16 pixels (digital) or 0.42 cm (print).</p>
          </div>
          <div class="card"><div class="specimen"><img src={`${base}/logo/section-1/minimum-size.png`} alt="Logo minimum size" /></div></div>
        </div>

        <div class="logo-part">
          <span class="logo-part-num">Section 2</span>
          <h3 class="logo-part-title">Logo color treatments</h3>
        </div>

        <!-- ===== Full-color (primary lockup) ===== -->
        <p class="subhead" style="margin-top:18px;">Full-color wordmark — correct use</p>
        <p class="note">The full-color wordmark is the primary lockup. Use it on clean, high-contrast backgrounds.</p>
        <div class="grid grid-2">
          <div class="card"><div class="card-label">On white</div><div class="specimen"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="Full-color wordmark on a white background" /></div></div>
          <div class="card"><div class="card-label">On black</div><div class="specimen"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-black.png`} alt="Full-color wordmark on a black background" /></div></div>
        </div>

        <div class="logo-row">
          <div class="logo-row-text">
            <p class="subhead" style="margin:0 0 8px;">On dark images</p>
            <p class="note" style="margin:0;">When placing the full-color wordmark over imagery, apply a linear dark layer behind it — 100% at the bottom fading to 0% toward the top — and a slight progressive blur over the same area, strongest at the bottom and easing to 0 at the top, so the wordmark stays legible against the photo.</p>
          </div>
          <div class="card"><div class="specimen"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-use-on-dark-images.jpg`} alt="Full-color wordmark over a dark photograph" /></div></div>
        </div>

        <p class="subhead" style="margin-top:28px;">Full-color wordmark — do not use</p>
        <div class="grid grid-3 dont">
          <div class="card"><div class="card-label">Don't place on light images</div><div class="specimen"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-do-not-use-on-light-images.jpg`} alt="Incorrect: full-color wordmark on a bright, busy photograph" /></div></div>
          <div class="card"><div class="card-label">Don't place on red gradients</div><div class="specimen"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-do-not-use-on-red-gradients.jpg`} alt="Incorrect: full-color wordmark on a red gradient" /></div></div>
          <div class="card"><div class="card-label">Don't place on white/light gradients</div><div class="specimen"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-do-not-use-on-white-gradients.jpg`} alt="Incorrect: full-color wordmark on a low-contrast light gradient" /></div></div>
        </div>

        <!-- ===== Red (one-color) ===== -->
        <p class="subhead" style="margin-top:36px;">Red wordmark — correct use</p>
        <p class="note">The red wordmark is the primary one-color treatment. Use it on clean, high-contrast backgrounds.</p>
        <div class="grid grid-2">
          <div class="card"><div class="card-label">On white</div><div class="specimen"><img src={`${base}/logo/section-2-2/ta-red-wordmark-over-white.png`} alt="Red wordmark on a white background" /></div></div>
          <div class="card"><div class="card-label">On black</div><div class="specimen"><img src={`${base}/logo/section-2-2/ta-red-wordmark-over-black.png`} alt="Red wordmark on a black background" /></div></div>
        </div>

        <p class="subhead" style="margin-top:28px;">Red wordmark — do not use</p>
        <div class="grid grid-2 dont">
          <div class="card"><div class="card-label">Don't place on busy images</div><div class="specimen"><img src={`${base}/logo/section-2-2/ta-red-wordmark-do-not-use-on-images.jpg`} alt="Incorrect: red wordmark placed over a busy photograph" /></div></div>
          <div class="card"><div class="card-label">Don't place on red gradients</div><div class="specimen"><img src={`${base}/logo/section-2-2/ta-red-wordmark-do-not-use-on-red-gradients.jpg`} alt="Incorrect: red wordmark on a low-contrast red gradient" /></div></div>
        </div>

        <!-- ===== White (one-color) ===== -->
        <p class="subhead" style="margin-top:36px;">White wordmark — correct use</p>
        <p class="note">Use the white wordmark on dark or saturated brand backgrounds, and over suitably dark imagery.</p>
        <div class="grid grid-2">
          <div class="card"><div class="card-label">On black</div><div class="specimen"><img src={`${base}/logo/section-2-3/ta-white-wordmark-over-black.png`} alt="White wordmark on a black background" /></div></div>
          <div class="card"><div class="card-label">On red</div><div class="specimen"><img src={`${base}/logo/section-2-3/ta-white-wordmark-over-red.png`} alt="White wordmark on the brand red" /></div></div>
        </div>

        <div class="logo-row">
          <div class="logo-row-text">
            <p class="subhead" style="margin:0 0 8px;">On dark images</p>
            <p class="note" style="margin:0;">When placing the white wordmark over imagery, apply a linear dark layer behind it — 100% at the bottom fading to 0% toward the top — and a slight progressive blur over the same area, strongest at the bottom and easing to 0 at the top, so the wordmark stays legible against the photo.</p>
          </div>
          <div class="card"><div class="specimen"><img src={`${base}/logo/section-2-3/ta-white-wordmark-use-on-dark-images.jpg`} alt="White wordmark over a dark photograph" /></div></div>
        </div>

        <p class="subhead" style="margin-top:28px;">White wordmark — do not use</p>
        <div class="grid grid-2 dont">
          <div class="card"><div class="card-label">Don't place on light images</div><div class="specimen"><img src={`${base}/logo/section-2-3/ta-white-wordmark-do-not-use-on-light-images.jpg`} alt="Incorrect: white wordmark on a bright, busy photograph" /></div></div>
          <div class="card"><div class="card-label">Don't place on white/light gradients</div><div class="specimen"><img src={`${base}/logo/section-2-3/ta-white-wordmark-do-not-use-on-white-gradients.jpg`} alt="Incorrect: white wordmark on a low-contrast light gradient" /></div></div>
        </div>

        <!-- ===== Black (one-color) ===== -->
        <p class="subhead" style="margin-top:36px;">Black wordmark — correct use</p>
        <div class="logo-row">
          <div class="logo-row-text">
            <p class="subhead" style="margin:0 0 8px;">On white</p>
            <p class="note" style="margin:0;">Use the black wordmark on white or light, low-detail backgrounds only — where it keeps clear contrast.</p>
          </div>
          <div class="card"><div class="specimen"><img src={`${base}/logo/section-2-4/ta-black-wordmark-over-white.png`} alt="Black wordmark on a white background" /></div></div>
        </div>

        <p class="subhead" style="margin-top:28px;">Black wordmark — do not use</p>
        <div class="grid grid-3 dont">
          <div class="card"><div class="card-label">Don't place on busy images</div><div class="specimen"><img src={`${base}/logo/section-2-4/ta-black-wordmark-do-not-use-on-images.jpg`} alt="Incorrect: black wordmark over a busy photograph" /></div></div>
          <div class="card"><div class="card-label">Don't place on red gradients</div><div class="specimen"><img src={`${base}/logo/section-2-4/ta-black-wordmark-do-not-use-on-red-gradients.jpg`} alt="Incorrect: black wordmark on a red gradient" /></div></div>
          <div class="card"><div class="card-label">Don't place on red</div><div class="specimen"><img src={`${base}/logo/section-2-4/ta-black-wordmark-do-not-use-on-red.png`} alt="Incorrect: black wordmark on the brand red" /></div></div>
        </div>

        <div class="logo-part">
          <span class="logo-part-num">Section 3</span>
          <h3 class="logo-part-title">In context</h3>
        </div>
        <p class="note">Mockup gallery — the logo applied across real-world surfaces.</p>
        <div class="bento gallery">
          <figure class="tile"><img src={`${base}/logo/section-3/ta-combination-logo-mockup-01.jpg`} alt="Logo in a website navigation bar" loading="lazy" /></figure>
          <figure class="tile"><img src={`${base}/logo/section-3/ta-combination-logo-mockup-04.jpg`} alt="Logo as office wall signage" loading="lazy" /></figure>
          <figure class="tile"><img src={`${base}/logo/section-3/ta-combination-logo-mockup-02.jpg`} alt="Logo in an email signature on a laptop" loading="lazy" /></figure>
          <figure class="tile"><img src={`${base}/logo/section-3/ta-combination-logo-mockup-03.jpg`} alt="Logo on a social media post" loading="lazy" /></figure>
        </div>
        <div class="logo-part">
          <span class="logo-part-num">Section 4</span>
          <h3 class="logo-part-title">Misuse</h3>
        </div>
        <p class="note">Our logo is the signature on everything we make — the shortest version of our promise. <strong style="color:var(--label);">It's precious to us, so please treat it with care.</strong> Give it room to breathe, keep it whole, and never bend it to fit. Look after these few rules and the mark looks after us — earning recognition and trust everywhere it appears.</p>
        <div class="grid grid-3">
          <div class="card"><div class="card-label">Don't stretch</div><div class="specimen misuse m-stretch"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't compress</div><div class="specimen misuse m-compress"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't rotate</div><div class="specimen misuse m-rotate"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't skew</div><div class="specimen misuse m-skew"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't recolor</div><div class="specimen misuse m-recolor"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't desaturate</div><div class="specimen misuse m-gray"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't reduce opacity</div><div class="specimen misuse m-fade"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't blur</div><div class="specimen misuse m-blur"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't invert</div><div class="specimen misuse m-invert"><img src={`${base}/logo/section-2-1/ta-full-color-wordmark-over-white.png`} alt="" /></div></div>
        </div>

        <div class="logo-part">
          <h3 class="logo-part-title">The mark</h3>
        </div>
        <p class="note">The standalone mark — for avatars, app icons, favicons, and tight spaces where the full lockup won't fit.</p>

        <!-- Clearspace -->
        <div class="logo-row">
          <div class="logo-row-text">
            <p class="subhead" style="margin:0 0 8px;">Clearspace</p>
            <p class="note" style="margin:0;">Keep clear space around the mark on all sides — exact value to confirm.</p>
          </div>
          <div class="card mark-shot"><div class="specimen square"><img src={`${base}/mark/mark-clearspace.png`} alt="Mark clearspace guidelines" /></div></div>
        </div>

        <!-- Applications -->
        <p class="subhead">Applications</p>
        <div class="grid grid-2">
          <div class="card mark-shot"><div class="card-label">App icon</div><div class="specimen square"><img src={`${base}/mark/mark-app-icon.jpg`} alt="The mark as an app icon on a phone home screen" /></div></div>
          <div class="card mark-shot"><div class="card-label">Social media avatar</div><div class="specimen square"><img src={`${base}/mark/mark-socialmedia.jpg`} alt="The mark as a social media profile avatar" /></div></div>
        </div>

        <!-- The mark on backgrounds (square) -->
        <p class="subhead">The mark on backgrounds</p>
        <div class="grid grid-3">
          <div class="card"><div class="card-label">Red on white</div><div class="specimen square"><img src={`${base}/mark/mark-use-01.png`} alt="Red mark on white" /></div></div>
          <div class="card"><div class="card-label">Red on dark</div><div class="specimen square"><img src={`${base}/mark/mark-use-02.png`} alt="Red mark on dark" /></div></div>
          <div class="card"><div class="card-label">Cream on red</div><div class="specimen square"><img src={`${base}/mark/mark-use-03.png`} alt="Cream mark on the brand red" /></div></div>
          <div class="card"><div class="card-label">Cream on dark</div><div class="specimen square"><img src={`${base}/mark/mark-use-04.png`} alt="Cream mark on dark" /></div></div>
          <div class="card"><div class="card-label">Over imagery</div><div class="specimen square"><img src={`${base}/mark/mark-use-05.jpg`} alt="Solid mark over a photograph" /></div></div>
          <div class="card"><div class="card-label">Outline over imagery</div><div class="specimen square"><img src={`${base}/mark/mark-use-06.jpg`} alt="Outlined mark over a photograph" /></div></div>
        </div>

        <!-- Things to avoid -->
        <p class="subhead">Things to avoid</p>
        <p class="note">Common misuse of the mark — avoid all of these.</p>
        <div class="grid grid-3">
          <div class="card"><div class="card-label">Don't stretch</div><div class="specimen square misuse m-stretch"><img src={`${base}/mark/mark-use-01.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't compress</div><div class="specimen square misuse m-compress"><img src={`${base}/mark/mark-use-01.png`} alt="" /></div></div>
          <div class="card"><div class="card-label">Don't rotate</div><div class="specimen square misuse m-rotate"><img src={`${base}/mark/mark-use-01.png`} alt="" /></div></div>
