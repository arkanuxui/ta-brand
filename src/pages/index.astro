  <script>
    // Mobile nav drawer
    const btn = document.getElementById('menuBtn');
    const sb = document.getElementById('sidebar');
    const scrim = document.getElementById('scrim');
    const navClose = document.getElementById('navClose');
    const closeNav = () => { sb.classList.remove('open'); scrim.classList.remove('show'); };
    btn?.addEventListener('click', () => { sb.classList.toggle('open'); scrim.classList.toggle('show'); });
    scrim?.addEventListener('click', closeNav);
    navClose?.addEventListener('click', closeNav);

    // ----- Paged navigation: show one section ("page") at a time -----
    const navLinks = Array.from(document.querySelectorAll('a[data-spy]'));
    const pages = ['introduction', 'logo', 'color', 'typography', 'tone-voice'];
    const setPage = (id, push) => {
      if (pages.indexOf(id) === -1) id = 'introduction';
      document.querySelectorAll('.section').forEach((s) => s.classList.toggle('is-active', s.id === id));
      Array.from(document.body.classList).forEach((c) => { if (c.indexOf('page-') === 0) document.body.classList.remove(c); });
      document.body.classList.add('page-' + id);
      navLinks.forEach((a) => a.classList.toggle('active', a.dataset.spy === id));
      if (push) {
        const url = id === 'introduction' ? (location.pathname + location.search) : ('#' + id);
        history.pushState({ page: id }, '', url);
      }
      window.scrollTo(0, 0);
    };
    navLinks.forEach((a) => a.addEventListener('click', (e) => {
      e.preventDefault();
      setPage(a.dataset.spy, true);
      closeNav();
    }));
    window.addEventListener('popstate', () => {
      setPage(location.hash ? location.hash.slice(1) : 'introduction', false);
    });
    // Initial page from the URL hash (or Introduction by default)
    setPage(location.hash ? location.hash.slice(1) : 'introduction', false);

    // Theme toggle (segmented Light / Dark control in the sidebar)
    const root = document.documentElement;
    const themeOpts = Array.from(document.querySelectorAll('.theme-opt'));
    const themeMeta = document.querySelector('meta[name="theme-color"]');
    const mql = window.matchMedia('(prefers-color-scheme: dark)');
    const applyTheme = (theme) => {
      root.setAttribute('data-theme', theme);
      if (themeMeta) themeMeta.setAttribute('content', theme === 'dark' ? '#191919' : '#ffffff');
      themeOpts.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.themeValue === theme)));
    };
    applyTheme(root.getAttribute('data-theme') || (mql.matches ? 'dark' : 'light'));
    themeOpts.forEach((b) => b.addEventListener('click', () => {
      const next = b.dataset.themeValue;
      try { localStorage.setItem('theme', next); } catch (e) {}
      applyTheme(next);
    }));
    // Follow the OS only while the user hasn't made an explicit choice
    mql.addEventListener('change', (e) => {
      try { if (localStorage.getItem('theme')) return; } catch (err) {}
      applyTheme(e.matches ? 'dark' : 'light');
    });

    document.querySelectorAll('.anchor').forEach((a) => {
      a.addEventListener('click', (ev) => {
        ev.preventDefault();
        const url = location.origin + location.pathname + a.getAttribute('href');
        navigator.clipboard?.writeText(url);
      });
    });

    // Click-to-copy for the full Tailwind palette chips
    document.addEventListener('click', (e) => {
      const chip = e.target.closest('.tw-chip[data-copy]');
      if (!chip) return;
      navigator.clipboard?.writeText(chip.dataset.copy);
      const cap = chip.querySelector('.tw-cap');
      const prev = cap ? cap.textContent : null;
      chip.classList.add('copied');
      if (cap) cap.textContent = 'Copied';
      setTimeout(() => { chip.classList.remove('copied'); if (cap) cap.textContent = prev; }, 1000);
    });
  </script>
</body>
